# ============================================================
# Environment variables for LDA Docker deployment
# ============================================================
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
# ============================================================

# --- Required: Supabase ---
# Found at: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# --- Required: Groq ---
# Found at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# --- Optional ---
STREAMLIT_PORT=8501
APP_NAME=LDA
APP_ANALYSIS_LIMIT=15
APP_SESSION_TIMEOUT_HOURS=24
